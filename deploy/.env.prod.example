DATABASE_APPLY_MIGRATIONS=true

JWT_ISSUER=HealthCareMS
JWT_AUDIENCE=HealthCareMS.Client
JWT_SIGNING_KEY=ReplaceWithAtLeast32CharactersLongSigningSecret

