@using HealthCareMS.Blazor.Services
@inject HealthCareApiClient ApiClient
@inject AppCultureService CultureService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand premium-brand" href="">
            <span class="brand-mark">H</span>
            <span>
                HealthCareMS
                <small>Enterprise Suite</small>
            </span>
        </a>
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm @(culture == "en" ? "btn-light" : "btn-outline-light")" @onclick='() => SetCultureAsync("en")'>EN</button>
            <button class="btn btn-sm @(culture == "ur" ? "btn-light" : "btn-outline-light")" @onclick='() => SetCultureAsync("ur")'>UR</button>
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="nav-item px-3 text-warning">@ErrorMessage</div>
        }

        @foreach (var group in MenuGroups)
        {
            <div class="nav-section">@group.Label</div>
            @foreach (var item in group.Items.OrderBy(x => x.SortOrder))
            {
                @RenderMenuItem(item, 0)
            }
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string culture = "en";
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<NavigationMenuGroupModel> MenuGroups { get; set; } = [];

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        culture = CultureService.CurrentCulture;
        await LoadMenuAsync();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task SetCultureAsync(string value)
    {
        culture = string.Equals(value, "ur", StringComparison.OrdinalIgnoreCase) ? "ur" : "en";
        await CultureService.SetCultureAsync(culture);
        await LoadMenuAsync();
    }

    private async Task LoadMenuAsync()
    {
        ErrorMessage = null;
        var response = await ApiClient.GetAsync<NavigationMenuModel>($"api/v1/system/navigation?culture={culture}");
        if (response?.Success != true || response.Data is null)
        {
            ErrorMessage = "Navigation could not be loaded.";
            MenuGroups = [];
            return;
        }

        MenuGroups = response.Data.Groups.OrderBy(x => x.SortOrder).ToList();
    }

    private RenderFragment RenderMenuItem(NavigationMenuItemModel item, int depth) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "nav-item px-3");
        builder.AddAttribute(sequence++, "style", depth == 0 ? string.Empty : $"padding-left:{0.75m + depth * 0.85m}rem;");

        builder.OpenComponent<NavLink>(sequence++);
        builder.AddAttribute(sequence++, "class", "nav-link");
        builder.AddAttribute(sequence++, "href", item.Route);
        builder.AddAttribute(sequence++, "Match", string.IsNullOrEmpty(item.Route) ? NavLinkMatch.All : NavLinkMatch.Prefix);
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(contentBuilder =>
        {
            var innerSeq = 0;
            contentBuilder.OpenElement(innerSeq++, "span");
            contentBuilder.AddAttribute(innerSeq++, "class", "nav-symbol");
            contentBuilder.AddAttribute(innerSeq++, "aria-hidden", "true");
            contentBuilder.AddContent(innerSeq++, item.Icon);
            contentBuilder.CloseElement();
            contentBuilder.AddContent(innerSeq++, $" {item.Label}");
        }));
        builder.CloseComponent();
        builder.CloseElement();

        foreach (var child in item.Children.OrderBy(x => x.SortOrder))
        {
            builder.AddContent(sequence++, RenderMenuItem(child, depth + 1));
        }
    };
}
