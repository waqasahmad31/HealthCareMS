@page "/doctors"
@using HealthCareMS.Blazor.Models
@using HealthCareMS.Blazor.Services
@inject HealthCareApiClient ApiClient

<PageTitle>Doctors Workspace</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Doctor Operations</p>
        <h1>Doctor Discovery, Credential, And Availability Workspace</h1>
    </div>
    <div class="header-actions">
        <button class="secondary-button" type="button" @onclick="LoadDoctorsAsync" disabled="@IsBusy">Refresh Search</button>
        <button class="secondary-button" type="button" @onclick="LoadAvailabilityAsync" disabled="@(IsBusy || SelectedDoctor is null)">Load Slots</button>
        <button class="primary-button" type="button" @onclick="SaveDoctorProfileAsync" disabled="@(IsBusy || SelectedDoctor is null)">Save Doctor</button>
    </div>
</section>

@if (SelectedDoctor is not null)
{
    <section class="stats-grid portal-stats">
        <article class="metric-card">
            <span class="metric-label">Selected Doctor</span>
            <strong>@SelectedDoctor.FullName</strong>
            <span class="tone-blue">@SelectedDoctor.Specialization</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Rating</span>
            <strong>@SelectedDoctor.AverageRating.ToString("0.0")</strong>
            <span class="tone-green">@SelectedDoctor.RatingCount reviews</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Schedules</span>
            <strong>@ScheduleEditor.Count</strong>
            <span class="tone-amber">editable slots</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Available Slots</span>
            <strong>@AvailableSlots.Count</strong>
            <span class="tone-muted">@SlotAppointmentType / @SlotDateText</span>
        </article>
    </section>

    <section class="portal-grid">
        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="panel-subtitle">Operational context</p>
                    <h2>Doctor Snapshot</h2>
                </div>
                <span class="@VerificationPillClass">@VerificationPillText</span>
            </div>
            <div class="dispense-summary">
                <strong>@SelectedDoctor.FullName</strong>
                <span>@DisplayText(SelectedDoctor.City, "City pending") / @SelectedDoctor.ConsultationFee.ToString("0") fee</span>
                <span>PMDC @SelectedDoctor.PmdcRegistrationNumber</span>
            </div>
            @if (SelectedDoctorSignals.Count > 0)
            {
                <div class="selected-tests">
                    @foreach (var signal in SelectedDoctorSignals)
                    {
                        <span>@signal</span>
                    }
                </div>
            }
        </article>

        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="panel-subtitle">Premium shortcuts</p>
                    <h2>Next Actions</h2>
                </div>
                <span class="status-pill blue">Cross-module</span>
            </div>
            <div class="module-grid">
                <a class="module-tile" href="@($"/appointments?doctorId={SelectedDoctor.Id}")">
                    <strong>Schedule Appointment</strong>
                    <span>Carry doctor context straight into booking orchestration</span>
                </a>
                <a class="module-tile" href="@($"/portal/doctor?doctorId={SelectedDoctor.Id}")">
                    <strong>Doctor Portal</strong>
                    <span>Open queue, schedule, and history from the same doctor context</span>
                </a>
                <a class="module-tile" href="@DoctorDiscoveryLink">
                    <strong>Recommendation View</strong>
                    <span>Preview how discovery ranks this doctor by city and specialization</span>
                </a>
                <a class="module-tile" href="/admin/doctors">
                    <strong>Admin Oversight</strong>
                    <span>Escalate to credential and performance governance</span>
                </a>
            </div>
        </article>
    </section>
}

<section class="portal-grid">
    <article class="panel">
        <div class="panel-header">
            <div>
                <p class="panel-subtitle">Step 1</p>
                <h2>Discovery Search</h2>
            </div>
            <span class="status-pill blue">@DoctorResults.Count</span>
        </div>
        <div class="dispense-summary">
            <strong>Search by operational fit</strong>
            <span>Filter doctors by specialization, city, and fee to shortlist the right clinician for the patient journey.</span>
        </div>
        <div class="entity-form">
            <label>Specialization<InputText @bind-Value="SpecializationFilter" placeholder="Cardiology, Neurology, Dermatology" /></label>
            <label>City<InputText @bind-Value="CityFilter" placeholder="Karachi, Lahore, Islamabad" /></label>
            <label>Max Fee<InputNumber @bind-Value="MaxFeeFilter" /></label>
        </div>
        <div class="panel-toolbar action-cluster">
            <button class="secondary-button" type="button" @onclick="LoadDoctorsAsync" disabled="@IsBusy">Search</button>
            <button class="text-button" type="button" @onclick="ResetDoctorSearch">Reset</button>
        </div>
        @if (DoctorResults.Count == 0)
        {
            <div class="empty-state">No doctors matched the current filters. Adjust search criteria to expand the shortlist.</div>
        }
        else
        {
            <div class="table-shell">
                <div class="table-row table-head">
                    <span>Doctor</span>
                    <span>Location</span>
                    <span>Fee / Rating</span>
                    <span></span>
                </div>
                @foreach (var doctor in DoctorResults)
                {
                    <div class="table-row">
                        <span>@doctor.FullName<br />@doctor.Specialization</span>
                        <span>@doctor.City</span>
                        <span>@doctor.ConsultationFee.ToString("0") / @doctor.AverageRating.ToString("0.0")</span>
                        <button class="secondary-button small-button" type="button" @onclick="() => SelectDoctorAsync(doctor.Id)">Open</button>
                    </div>
                }
            </div>
        }
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <p class="panel-subtitle">Step 2</p>
                <h2>Doctor Profile</h2>
            </div>
            <span class="@VerificationPillClass">@VerificationPillText</span>
        </div>
        @if (SelectedDoctor is null)
        {
            <div class="empty-state">Search and select a doctor to unlock profile, verification, and schedule tools.</div>
        }
        else
        {
            <div class="dispense-summary">
                <strong>@SelectedDoctor.FullName</strong>
                <span>@SelectedDoctor.Email / @DisplayText(SelectedDoctor.PhoneNumber, "No phone")</span>
                <span>@SelectedDoctorKey</span>
            </div>
            <div class="entity-form">
                <label>Specialization<InputText @bind-Value="DoctorProfileForm.Specialization" /></label>
                <label>Qualification<InputText @bind-Value="DoctorProfileForm.Qualification" /></label>
                <label>City<InputText @bind-Value="DoctorProfileForm.City" /></label>
                <label>Consultation Fee<InputNumber @bind-Value="DoctorProfileForm.ConsultationFee" /></label>
                <label>Biography<InputTextArea @bind-Value="DoctorProfileForm.Biography" /></label>
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="DoctorProfileForm.IsActive" />
                    Active Profile
                </label>
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="VerifyForm.IsVerified" />
                    Verified
                </label>
            </div>
            <div class="panel-toolbar action-cluster">
                <button class="secondary-button" type="button" @onclick="UpdateVerificationAsync" disabled="@IsBusy">Update Verification</button>
                <button class="primary-button" type="button" @onclick="SaveDoctorProfileAsync" disabled="@IsBusy">Save Profile</button>
            </div>
        }
    </article>
</section>

<section class="portal-grid">
    <article class="panel">
        <div class="panel-header">
            <div>
                <p class="panel-subtitle">Step 3</p>
                <h2>Schedule Studio</h2>
            </div>
            <span class="status-pill green">@ScheduleEditor.Count slots</span>
        </div>
        @if (SelectedDoctor is null)
        {
            <div class="empty-state">Select a doctor to edit recurring weekly schedule slots.</div>
        }
        else
        {
            <div class="dispense-summary">
                <strong>Recurring slot design</strong>
                <span>Use weekly slots to define clinic rhythm and online coverage before opening booking inventory.</span>
                <span>@ScheduleCoverageSummary</span>
            </div>
            <div class="entity-form">
                <label>
                    Day
                    <InputSelect @bind-Value="NewSlot.DayOfWeek">
                        @foreach (var day in DaysOfWeek)
                        {
                            <option value="@day">@day</option>
                        }
                    </InputSelect>
                </label>
                <label>Start<input type="time" value="@NewSlotStartTimeText" @onchange="OnNewSlotStartChanged" /></label>
                <label>End<input type="time" value="@NewSlotEndTimeText" @onchange="OnNewSlotEndChanged" /></label>
                <label>Duration<InputNumber @bind-Value="NewSlot.SlotDurationMinutes" /></label>
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="NewSlot.IsOnlineAvailable" />
                    Online
                </label>
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="NewSlot.IsOnSiteAvailable" />
                    OnSite
                </label>
            </div>
            <div class="panel-toolbar action-cluster">
                <button class="secondary-button" type="button" @onclick="AddScheduleSlot">Add Slot</button>
                <button class="primary-button" type="button" @onclick="SaveScheduleAsync" disabled="@IsBusy">Save Schedule</button>
            </div>
            @if (ScheduleEditor.Count == 0)
            {
                <div class="empty-state">No schedule slots configured yet. Add at least one weekly slot to expose bookable inventory.</div>
            }
            else
            {
                <div class="table-shell">
                    <div class="table-row table-head">
                        <span>Day</span>
                        <span>Window</span>
                        <span>Mode</span>
                        <span></span>
                    </div>
                    @foreach (var slot in ScheduleEditor)
                    {
                        <div class="table-row">
                            <span>@slot.DayOfWeek</span>
                            <span>@slot.StartTime.ToString("HH\\:mm") - @slot.EndTime.ToString("HH\\:mm")</span>
                            <span>@ModeLabel(slot)</span>
                            <button class="secondary-button small-button" type="button" @onclick="() => RemoveScheduleSlot(slot)">Remove</button>
                        </div>
                    }
                </div>
            }
        }
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <p class="panel-subtitle">Step 4</p>
                <h2>Reviews And Availability</h2>
            </div>
            <span class="status-pill blue">@AvailableSlots.Count slots</span>
        </div>
        @if (SelectedDoctor is null)
        {
            <div class="empty-state">Choose a doctor to review patient sentiment and slot inventory.</div>
        }
        else
        {
            <div class="entity-form">
                <label>Slot Date<input type="date" value="@SlotDateText" @onchange="OnSlotDateChanged" /></label>
                <label>
                    Appointment Type
                    <InputSelect @bind-Value="SlotAppointmentType">
                        <option>Online</option>
                        <option>OnSite</option>
                    </InputSelect>
                </label>
            </div>
            <div class="panel-toolbar action-cluster">
                <button class="secondary-button" type="button" @onclick="LoadAvailabilityAsync" disabled="@IsBusy">Load Availability</button>
                <button class="secondary-button" type="button" @onclick="LoadRatingSummaryAsync" disabled="@IsBusy">Refresh Reviews</button>
            </div>

            @if (RatingSummary is not null)
            {
                <div class="dispense-summary">
                    <strong>@RatingSummary.AverageRating.ToString("0.0") average rating</strong>
                    <span>@RatingSummary.RatingCount total reviews</span>
                    <span>@AvailabilityReadiness</span>
                </div>
            }

            @if (AvailableSlots.Count == 0)
            {
                <div class="empty-state">No open slots were found for the selected date and appointment type.</div>
            }
            else
            {
                <div class="table-shell">
                    @foreach (var slot in AvailableSlots)
                    {
                        <div class="table-row">
                            <span>@slot.StartTime.ToString("HH\\:mm")</span>
                            <span>@slot.EndTime.ToString("HH\\:mm")</span>
                            <span>@slot.AppointmentType</span>
                        </div>
                    }
                </div>
            }

            @if (RatingSummary?.RecentReviews.Count > 0)
            {
                <div class="table-shell">
                    @foreach (var review in RatingSummary.RecentReviews)
                    {
                        <div class="table-row">
                            <span>@review.PatientName</span>
                            <span>@review.Rating / 5</span>
                            <span>@DisplayText(review.ReviewText, "No written review")</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">Recent review feedback is not available yet for this doctor.</div>
            }
        }
    </article>
</section>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p class="@StatusClass">@StatusMessage</p>
}

@code {
    [SupplyParameterFromQuery(Name = "doctorId")]
    public Guid? PrefillDoctorId { get; set; }

    private static readonly string[] DaysOfWeek = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

    private IReadOnlyList<DoctorModel> DoctorResults { get; set; } = [];
    private IReadOnlyList<AvailableSlotModel> AvailableSlots { get; set; } = [];
    private List<DoctorScheduleSlotModel> ScheduleEditor { get; set; } = [];
    private DoctorModel? SelectedDoctor { get; set; }
    private DoctorRatingSummaryModel? RatingSummary { get; set; }
    private UpdateDoctorProfileModel DoctorProfileForm { get; set; } = new();
    private VerifyDoctorModel VerifyForm { get; set; } = new();
    private DoctorScheduleSlotModel NewSlot { get; set; } = new();
    private string SpecializationFilter { get; set; } = string.Empty;
    private string CityFilter { get; set; } = string.Empty;
    private decimal? MaxFeeFilter { get; set; }
    private DateOnly SlotDate { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow.Date.AddDays(1));
    private string SlotDateText { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow.Date.AddDays(1)).ToString("yyyy-MM-dd");
    private string SlotAppointmentType { get; set; } = "Online";
    private string NewSlotStartTimeText { get; set; } = string.Empty;
    private string NewSlotEndTimeText { get; set; } = string.Empty;
    private bool IsBusy { get; set; }
    private string? StatusMessage { get; set; }
    private string StatusClass { get; set; } = "tone-muted";
    private string? AppliedDoctorSignature { get; set; }
    private string VerificationPillText => SelectedDoctor is null ? "No doctor" : SelectedDoctor.IsVerified ? "Verified" : "Pending";
    private string VerificationPillClass => SelectedDoctor is null ? "status-pill blue" : SelectedDoctor.IsVerified ? "status-pill green" : "status-pill amber";
    private string SelectedDoctorKey => SelectedDoctor is null ? "No doctor" : SelectedDoctor.Id.ToString("N")[..8].ToUpperInvariant();
    private string ScheduleCoverageSummary => ScheduleEditor.Count == 0 ? "No weekly coverage configured yet." : $"{ScheduleEditor.Count} weekly slots ready for publishing.";
    private string AvailabilityReadiness => AvailableSlots.Count == 0 ? "No open inventory for this date" : $"{AvailableSlots.Count} bookable slots returned";
    private string DoctorDiscoveryLink => SelectedDoctor is null
        ? "/doctor-discovery"
        : $"/doctor-discovery?specialization={Uri.EscapeDataString(SelectedDoctor.Specialization)}&city={Uri.EscapeDataString(SelectedDoctor.City)}&appointmentType=Online";
    private IReadOnlyList<string> SelectedDoctorSignals => BuildDoctorSignals();

    protected override async Task OnInitializedAsync()
    {
        ResetNewSlotEditor();
        await LoadDoctorsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var signature = PrefillDoctorId?.ToString() ?? "-";
        if (signature == AppliedDoctorSignature)
        {
            return;
        }

        AppliedDoctorSignature = signature;

        if (PrefillDoctorId.HasValue)
        {
            await SelectDoctorAsync(PrefillDoctorId.Value);
        }
    }

    private async Task LoadDoctorsAsync()
    {
        var query = new List<string>();
        if (!string.IsNullOrWhiteSpace(SpecializationFilter))
        {
            query.Add($"specialization={Uri.EscapeDataString(SpecializationFilter)}");
        }

        if (!string.IsNullOrWhiteSpace(CityFilter))
        {
            query.Add($"city={Uri.EscapeDataString(CityFilter)}");
        }

        if (MaxFeeFilter.HasValue)
        {
            query.Add($"maxFee={MaxFeeFilter.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }

        var url = query.Count == 0 ? "api/v1/doctors" : $"api/v1/doctors?{string.Join("&", query)}";
        IsBusy = true;
        var result = await ApiClient.GetAsync<IReadOnlyList<DoctorModel>>(url);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            DoctorResults = result.Data;
            SetStatus(DoctorResults.Count == 0 ? "Doctor discovery refreshed. No doctors matched the active filters." : "Doctor discovery refreshed.", DoctorResults.Count == 0 ? "tone-blue" : "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Doctor discovery unavailable.", "tone-amber");
    }

    private async Task SelectDoctorAsync(Guid doctorId)
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<DoctorModel>($"api/v1/doctors/{doctorId}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            SelectedDoctor = result.Data;
            ApplyDoctor(result.Data);
            await LoadRatingSummaryAsync();
            await LoadAvailabilityAsync();
            SetStatus("Doctor profile loaded.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Doctor profile unavailable.", "tone-amber");
    }

    private async Task SaveDoctorProfileAsync()
    {
        if (SelectedDoctor is null)
        {
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PutAsync<UpdateDoctorProfileModel, DoctorModel>($"api/v1/doctors/{SelectedDoctor.Id}/profile", DoctorProfileForm);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            SelectedDoctor = result.Data;
            ApplyDoctor(result.Data);
            DoctorResults = DoctorResults.Select(x => x.Id == result.Data.Id ? result.Data : x).ToArray();
            SetStatus("Doctor profile updated.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Doctor profile update failed.", "tone-amber");
    }

    private async Task UpdateVerificationAsync()
    {
        if (SelectedDoctor is null)
        {
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PutAsync<VerifyDoctorModel, DoctorModel>($"api/v1/doctors/{SelectedDoctor.Id}/verify", VerifyForm);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            SelectedDoctor = result.Data;
            ApplyDoctor(result.Data);
            DoctorResults = DoctorResults.Select(x => x.Id == result.Data.Id ? result.Data : x).ToArray();
            SetStatus("Doctor verification updated.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Doctor verification update failed.", "tone-amber");
    }

    private async Task LoadRatingSummaryAsync()
    {
        if (SelectedDoctor is null)
        {
            return;
        }

        var result = await ApiClient.GetAsync<DoctorRatingSummaryModel>($"api/v1/doctors/{SelectedDoctor.Id}/rating");
        if (result?.Success == true && result.Data is not null)
        {
            RatingSummary = result.Data;
        }
        else
        {
            RatingSummary = null;
        }
    }

    private async Task LoadAvailabilityAsync()
    {
        if (SelectedDoctor is null)
        {
            return;
        }

        var result = await ApiClient.GetAsync<AvailableSlotModel[]>($"api/v1/doctors/{SelectedDoctor.Id}/available-slots?date={SlotDate:yyyy-MM-dd}&appointmentType={Uri.EscapeDataString(SlotAppointmentType)}&utcOffsetMinutes={LocalUtcOffsetMinutes}");
        if (result?.Success == true && result.Data is not null)
        {
            AvailableSlots = result.Data;
            SetStatus(AvailableSlots.Count == 0 ? "Doctor availability loaded, but no open slots were found for the selected criteria." : "Doctor availability loaded.", AvailableSlots.Count == 0 ? "tone-blue" : "tone-green");
            return;
        }

        AvailableSlots = [];
        SetStatus(result?.Error?.Message ?? "Doctor availability unavailable.", "tone-amber");
    }

    private static int LocalUtcOffsetMinutes => (int)DateTimeOffset.Now.Offset.TotalMinutes;

    private void AddScheduleSlot()
    {
        if (NewSlot.EndTime <= NewSlot.StartTime)
        {
            SetStatus("Schedule end time must be later than start time.", "tone-amber");
            return;
        }

        if (!NewSlot.IsOnlineAvailable && !NewSlot.IsOnSiteAvailable)
        {
            SetStatus("Enable at least one appointment mode before adding a slot.", "tone-amber");
            return;
        }

        if (ScheduleEditor.Any(slot =>
                slot.DayOfWeek == NewSlot.DayOfWeek &&
                slot.StartTime == NewSlot.StartTime &&
                slot.EndTime == NewSlot.EndTime &&
                slot.IsOnlineAvailable == NewSlot.IsOnlineAvailable &&
                slot.IsOnSiteAvailable == NewSlot.IsOnSiteAvailable))
        {
            SetStatus("This weekly slot already exists in the schedule editor.", "tone-amber");
            return;
        }

        ScheduleEditor.Add(new DoctorScheduleSlotModel
        {
            DayOfWeek = NewSlot.DayOfWeek,
            StartTime = NewSlot.StartTime,
            EndTime = NewSlot.EndTime,
            SlotDurationMinutes = NewSlot.SlotDurationMinutes,
            IsOnlineAvailable = NewSlot.IsOnlineAvailable,
            IsOnSiteAvailable = NewSlot.IsOnSiteAvailable
        });

        ResetNewSlotEditor();
        SetStatus("Schedule slot queued for save.", "tone-blue");
    }

    private void RemoveScheduleSlot(DoctorScheduleSlotModel slot)
    {
        ScheduleEditor.Remove(slot);
        SetStatus("Schedule slot removed from the local editor.", "tone-blue");
    }

    private async Task SaveScheduleAsync()
    {
        if (SelectedDoctor is null)
        {
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PutAsync<SetDoctorScheduleModel, DoctorModel>(
            $"api/v1/doctors/{SelectedDoctor.Id}/schedule",
            new SetDoctorScheduleModel { Slots = ScheduleEditor.ToArray() });
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            SelectedDoctor = result.Data;
            ApplyDoctor(result.Data);
            DoctorResults = DoctorResults.Select(x => x.Id == result.Data.Id ? result.Data : x).ToArray();
            SetStatus("Doctor schedule saved.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Doctor schedule save failed.", "tone-amber");
    }

    private void ApplyDoctor(DoctorModel doctor)
    {
        DoctorProfileForm = new UpdateDoctorProfileModel
        {
            Specialization = doctor.Specialization,
            Qualification = doctor.Qualification,
            Biography = doctor.Biography,
            City = doctor.City,
            ConsultationFee = doctor.ConsultationFee,
            IsActive = doctor.IsActive
        };
        VerifyForm = new VerifyDoctorModel { IsVerified = doctor.IsVerified };
        ScheduleEditor = doctor.Schedules
            .Select(slot => new DoctorScheduleSlotModel
            {
                DayOfWeek = slot.DayOfWeek,
                StartTime = slot.StartTime,
                EndTime = slot.EndTime,
                SlotDurationMinutes = slot.SlotDurationMinutes,
                IsOnlineAvailable = slot.IsOnlineAvailable,
                IsOnSiteAvailable = slot.IsOnSiteAvailable
            })
            .ToList();
    }

    private void ResetNewSlotEditor()
    {
        NewSlot = new DoctorScheduleSlotModel();
        NewSlotStartTimeText = NewSlot.StartTime.ToString("HH\\:mm");
        NewSlotEndTimeText = NewSlot.EndTime.ToString("HH\\:mm");
    }

    private void OnSlotDateChanged(ChangeEventArgs args)
    {
        SlotDateText = args.Value?.ToString() ?? string.Empty;
        if (DateOnly.TryParse(SlotDateText, out var parsed))
        {
            SlotDate = parsed;
        }
    }

    private void OnNewSlotStartChanged(ChangeEventArgs args)
    {
        NewSlotStartTimeText = args.Value?.ToString() ?? string.Empty;
        if (TimeOnly.TryParse(NewSlotStartTimeText, out var parsed))
        {
            NewSlot.StartTime = parsed;
        }
    }

    private void OnNewSlotEndChanged(ChangeEventArgs args)
    {
        NewSlotEndTimeText = args.Value?.ToString() ?? string.Empty;
        if (TimeOnly.TryParse(NewSlotEndTimeText, out var parsed))
        {
            NewSlot.EndTime = parsed;
        }
    }

    private void ResetDoctorSearch()
    {
        SpecializationFilter = string.Empty;
        CityFilter = string.Empty;
        MaxFeeFilter = null;
    }

    private void SetStatus(string message, string statusClass)
    {
        StatusMessage = message;
        StatusClass = statusClass;
    }

    private IReadOnlyList<string> BuildDoctorSignals()
    {
        if (SelectedDoctor is null)
        {
            return [];
        }

        var signals = new List<string>
        {
            $"{SelectedDoctor.ConsultationFee.ToString("0")} fee",
            SelectedDoctor.City
        };

        if (SelectedDoctor.IsVerified)
        {
            signals.Add("Verified");
        }

        if (ScheduleEditor.Count > 0)
        {
            signals.Add($"{ScheduleEditor.Count} weekly slots");
        }

        if (AvailableSlots.Count > 0)
        {
            signals.Add($"{AvailableSlots.Count} open slots");
        }

        if (SelectedDoctor.RatingCount > 0)
        {
            signals.Add($"{SelectedDoctor.RatingCount} reviews");
        }

        return signals;
    }

    private static string DisplayText(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    }

    private static string ModeLabel(DoctorScheduleSlotModel slot)
    {
        if (slot.IsOnlineAvailable && slot.IsOnSiteAvailable)
        {
            return "Online + OnSite";
        }

        if (slot.IsOnlineAvailable)
        {
            return "Online";
        }

        if (slot.IsOnSiteAvailable)
        {
            return "OnSite";
        }

        return "Inactive";
    }
}
