@page "/consultation/complete"
@using HealthCareMS.Blazor.Models
@using HealthCareMS.Blazor.Services
@inject HealthCareApiClient ApiClient
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation

<PageTitle>Complete Consultation</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Doctor</p>
        <h1>Complete Consultation</h1>
    </div>
    <button class="primary-button" type="button" @onclick="CompleteAsync" disabled="@IsBusy">Complete</button>
</section>

<section class="consultation-grid">
    <article class="panel">
        <div class="panel-header">
            <h2>Diagnosis</h2>
            <span class="status-pill blue">ICD-10</span>
        </div>
        <EditForm Model="Form" class="entity-form">
            <label>
                AppointmentId
                <InputText @bind-Value="Form.AppointmentIdText" />
            </label>
            <label>
                PatientId
                <InputText @bind-Value="Form.PatientIdText" />
            </label>
            <label>
                ICD-10 Search
                <InputText @bind-Value="Icd10Search" />
            </label>
            <button class="secondary-button" type="button" @onclick="SearchIcd10Async" disabled="@IsBusy">Search</button>
            <label>
                ICD-10 Code
                <InputSelect @bind-Value="Form.Icd10Code">
                    <option value="">Uncoded</option>
                    @foreach (var code in Icd10Results)
                    {
                        <option value="@(code.Code)">@(code.Code) - @(code.Title)</option>
                    }
                </InputSelect>
            </label>
            <label>
                Diagnosis
                <InputTextArea @bind-Value="Form.Diagnosis" />
            </label>
            <label>
                ClinicalNotes
                <InputTextArea @bind-Value="Form.ClinicalNotes" />
            </label>
            <label>
                FollowUpDate
                <input type="date" value="@FollowUpDateText" @onchange="OnFollowUpDateChanged" />
            </label>
        </EditForm>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>Prescription</h2>
            <div class="header-actions">
                <button class="secondary-button" type="button" @onclick="CheckAllergiesAsync" disabled="@IsBusy">Check Allergies</button>
                <button class="secondary-button" type="button" @onclick="AddMedicine" disabled="@IsBusy">Add</button>
            </div>
        </div>

        <div class="prescription-builder">
            <div class="medicine-search">
                <label>
                    DRAP Drug Search
                    <input list="drap-medicine-options" value="@MedicineSearch" @oninput="OnMedicineSearchChanged" />
                    <datalist id="drap-medicine-options">
                        @foreach (var medicine in DrapMedicineResults)
                        {
                            <option value="@medicine.BrandName">@medicine.GenericName @medicine.Strength</option>
                        }
                    </datalist>
                </label>
                <button class="secondary-button" type="button" @onclick="SearchDrapMedicinesAsync" disabled="@IsBusy">Search</button>
            </div>

            @if (DrapMedicineResults.Count > 0)
            {
                <div class="drug-results">
                    @foreach (var medicine in DrapMedicineResults)
                    {
                        <button class="@MedicineOptionClass(medicine)" type="button" @onclick="() => SelectMedicine(medicine)">
                            <strong>@medicine.BrandName</strong>
                            <span>@medicine.GenericName @medicine.Strength</span>
                            <code>@medicine.DrapRegistrationNumber</code>
                        </button>
                    }
                </div>
            }

            <div class="medicine-form">
                <label>
                    Medicine
                    <InputText @bind-Value="Medicine.MedicineName" />
                </label>
                <label>
                    Generic
                    <InputText @bind-Value="Medicine.GenericName" />
                </label>
                <label>
                    Strength
                    <InputText @bind-Value="Medicine.Strength" />
                </label>
                <label>
                    Route
                    <InputText @bind-Value="Medicine.Route" />
                </label>
                <label>
                    Dosage
                    <InputText @bind-Value="Medicine.Dosage" />
                </label>
                <label>
                    Frequency
                    <InputText @bind-Value="Medicine.Frequency" />
                </label>
                <label>
                    DurationDays
                    <InputNumber @bind-Value="Medicine.DurationDays" />
                </label>
                <label>
                    Quantity
                    <InputNumber @bind-Value="Medicine.Quantity" />
                </label>
                <label class="full-span">
                    Instructions
                    <InputText @bind-Value="Medicine.Instructions" />
                </label>
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="Medicine.IsSubstitutionAllowed" />
                    Substitution
                </label>
            </div>

            @if (AllergyWarnings.Count > 0)
            {
                <div class="warning-list" role="alert">
                    @foreach (var warning in AllergyWarnings)
                    {
                        <div class="warning-item">
                            <strong>@warning.Severity allergy warning</strong>
                            <span>@warning.Message</span>
                            <code>@warning.MatchedAllergy</code>
                        </div>
                    }
                </div>
            }

            <div class="table-shell prescription-list">
                <div class="table-row table-head prescription-row">
                    <span>Medicine</span>
                    <span>Dose</span>
                    <span>Qty</span>
                    <span></span>
                </div>
                @foreach (var item in PrescriptionItems)
                {
                    <div class="table-row prescription-row">
                        <span>@item.MedicineName</span>
                        <span>@item.Dosage / @item.Frequency</span>
                        <span>@item.Quantity</span>
                        <button class="secondary-button small-button" type="button" @onclick="() => RemoveMedicine(item)">Remove</button>
                    </div>
                }
            </div>
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>Lab Orders</h2>
            <div class="header-actions">
                <button class="secondary-button" type="button" @onclick="SearchLabTestsAsync" disabled="@IsBusy">Search</button>
                <button class="primary-button" type="button" @onclick="CreateLabOrderAsync" disabled="@IsBusy">Order</button>
            </div>
        </div>
        <div class="prescription-builder">
            <div class="medicine-search">
                <label>
                    Lab Test Search
                    <input value="@LabSearch" @oninput="OnLabSearchChanged" />
                </label>
                <select @bind="LabOrderCollectionType">
                    <option>OnSite</option>
                    <option>Home</option>
                </select>
            </div>
            <div class="entity-form">
                <label>
                    CollectionAddress
                    <InputText @bind-Value="LabCollectionAddress" />
                </label>
            </div>
            <div class="drug-results">
                @foreach (var test in LabTestResults)
                {
                    <button class="@LabTestOptionClass(test)" type="button" @onclick="() => ToggleLabTest(test)">
                        <strong>@test.TestCode</strong>
                        <span>@test.TestName</span>
                        <code>PKR @test.Price.ToString("0.##")</code>
                    </button>
                }
            </div>
            @if (SelectedLabTests.Count > 0)
            {
                <div class="table-shell">
                    @foreach (var test in SelectedLabTests)
                    {
                        <div class="table-row lab-order-row">
                            <span>@test.TestName</span>
                            <span>@test.Category</span>
                            <button class="secondary-button small-button" type="button" @onclick="() => ToggleLabTest(test)">Remove</button>
                        </div>
                    }
                </div>
            }
            @if (LabOrders.Count > 0)
            {
                <div class="table-shell">
                    @foreach (var order in LabOrders)
                    {
                        <div class="table-row lab-order-row">
                            <span>@order.BookingNumber</span>
                            <span>@order.Items.Count tests / PKR @order.TotalAmount.ToString("0.##")</span>
                            <span class="status-pill green">@order.Status</span>
                        </div>
                    }
                </div>
            }
        </div>
    </article>
</section>

@if (Result is not null)
{
    <section class="panel prescription-result">
        <div class="panel-header">
            <h2>@Result.Prescription?.PrescriptionNumber</h2>
            <div class="header-actions">
                <span class="status-pill green">@Result.Status</span>
                <button class="secondary-button" type="button" @onclick="DownloadPrescriptionPdfAsync" disabled="@IsBusy">PDF</button>
                <button class="secondary-button" type="button" @onclick="OpenSummary">Summary</button>
            </div>
        </div>
        <div class="permission-grid">
            <div class="permission-row">
                <code>@Result.Icd10Code</code>
                <span>@Result.Icd10Title</span>
            </div>
            <div class="permission-row">
                <code>@Result.AppointmentNumber</code>
                <span>@Result.Diagnosis</span>
            </div>
            <div class="permission-row">
                <code>@(Result.Prescription?.Items.Count ?? 0)</code>
                <span>Medicines</span>
            </div>
            <div class="permission-row">
                <code>@Result.Prescription?.VerificationCode</code>
                <span>Verification Code</span>
            </div>
            <div class="permission-row">
                <code>@ShortSignature(Result.Prescription?.DigitalSignature)</code>
                <span>Doctor Signature</span>
            </div>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p class="@StatusClass">@StatusMessage</p>
}

@code {
    private ConsultationForm Form { get; } = new();

    private MedicineForm Medicine { get; set; } = new();

    private List<PrescriptionItemModel> PrescriptionItems { get; } = [];

    private IReadOnlyList<Icd10CodeModel> Icd10Results { get; set; } = [];

    private IReadOnlyList<DrapMedicineModel> DrapMedicineResults { get; set; } = [];

    private IReadOnlyList<DrugAllergyWarningModel> AllergyWarnings { get; set; } = [];

    private IReadOnlyList<LabTestModel> LabTestResults { get; set; } = [];

    private List<LabTestModel> SelectedLabTests { get; } = [];

    private IReadOnlyList<LabBookingModel> LabOrders { get; set; } = [];

    private CompleteConsultationResultModel? Result { get; set; }

    private string Icd10Search { get; set; } = string.Empty;

    private string MedicineSearch { get; set; } = string.Empty;

    private string LabSearch { get; set; } = string.Empty;

    private string LabOrderCollectionType { get; set; } = "OnSite";

    private string? LabCollectionAddress { get; set; }

    private string FollowUpDateText { get; set; } = string.Empty;

    private bool IsBusy { get; set; }

    private string? StatusMessage { get; set; }

    private string StatusClass { get; set; } = "tone-muted";

    protected override async Task OnInitializedAsync()
    {
        await SearchIcd10Async();
        await SearchDrapMedicinesAsync();
        await SearchLabTestsAsync();
    }

    private async Task SearchIcd10Async()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<IReadOnlyList<Icd10CodeModel>>($"api/v1/consultations/icd10?search={Uri.EscapeDataString(Icd10Search)}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            Icd10Results = result.Data;
            Form.Icd10Code = Icd10Results.FirstOrDefault()?.Code;
            return;
        }

        SetStatus(result?.Error?.Message ?? "ICD-10 lookup unavailable.", "tone-amber");
    }

    private async Task SearchDrapMedicinesAsync()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<IReadOnlyList<DrapMedicineModel>>($"api/v1/consultations/drugs?search={Uri.EscapeDataString(MedicineSearch)}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            DrapMedicineResults = result.Data;
            return;
        }

        SetStatus(result?.Error?.Message ?? "DRAP drug lookup unavailable.", "tone-amber");
    }

    private async Task SearchLabTestsAsync()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<IReadOnlyList<LabTestModel>>($"api/v1/lab/tests?search={Uri.EscapeDataString(LabSearch)}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            LabTestResults = result.Data;
            return;
        }

        SetStatus(result?.Error?.Message ?? "Lab test lookup unavailable.", "tone-amber");
    }

    private async Task OnMedicineSearchChanged(ChangeEventArgs args)
    {
        MedicineSearch = args.Value?.ToString() ?? string.Empty;
        if (MedicineSearch.Length == 0 || MedicineSearch.Length >= 2)
        {
            await SearchDrapMedicinesAsync();
        }
    }

    private async Task OnLabSearchChanged(ChangeEventArgs args)
    {
        LabSearch = args.Value?.ToString() ?? string.Empty;
        if (LabSearch.Length == 0 || LabSearch.Length >= 2)
        {
            await SearchLabTestsAsync();
        }
    }

    private void SelectMedicine(DrapMedicineModel medicine)
    {
        MedicineSearch = $"{medicine.BrandName} ({medicine.GenericName})";
        Medicine.MedicineName = medicine.BrandName;
        Medicine.GenericName = medicine.GenericName;
        Medicine.Strength = medicine.Strength;
        Medicine.Route = Medicine.Route ?? "Oral";

        if (medicine.IsBanned)
        {
            SetStatus($"{medicine.BrandName} is DRAP-banned and cannot be prescribed.", "tone-amber");
        }
    }

    private async Task AddMedicine()
    {
        if (string.IsNullOrWhiteSpace(Medicine.MedicineName)
            || string.IsNullOrWhiteSpace(Medicine.Dosage)
            || string.IsNullOrWhiteSpace(Medicine.Frequency)
            || Medicine.DurationDays <= 0
            || Medicine.Quantity <= 0)
        {
            SetStatus("Medicine, dosage, frequency, duration, and quantity are required.", "tone-amber");
            return;
        }

        PrescriptionItems.Add(new PrescriptionItemModel(
            Medicine.MedicineName,
            Medicine.GenericName,
            Medicine.Strength,
            Medicine.Route,
            Medicine.Dosage,
            Medicine.Frequency,
            Medicine.DurationDays,
            Medicine.Quantity,
            Medicine.Instructions,
            Medicine.IsSubstitutionAllowed));

        Medicine = new MedicineForm();
        MedicineSearch = string.Empty;

        if (Guid.TryParse(Form.PatientIdText, out _))
        {
            await CheckAllergiesAsync(isAutomatic: true);
            return;
        }

        SetStatus("Medicine added.", "tone-green");
    }

    private async Task RemoveMedicine(PrescriptionItemModel item)
    {
        PrescriptionItems.Remove(item);
        if (PrescriptionItems.Count == 0)
        {
            AllergyWarnings = [];
            return;
        }

        if (Guid.TryParse(Form.PatientIdText, out _))
        {
            await CheckAllergiesAsync(isAutomatic: true);
        }
    }

    private async Task CheckAllergiesAsync()
    {
        await CheckAllergiesAsync(isAutomatic: false);
    }

    private async Task CheckAllergiesAsync(bool isAutomatic)
    {
        if (PrescriptionItems.Count == 0)
        {
            AllergyWarnings = [];
            if (!isAutomatic)
            {
                SetStatus("Add at least one medicine before allergy check.", "tone-amber");
            }
            return;
        }

        if (!Guid.TryParse(Form.PatientIdText, out var patientId))
        {
            if (!isAutomatic)
            {
                SetStatus("PatientId is required for allergy check.", "tone-amber");
            }
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<DrugAllergyCheckModel, IReadOnlyList<DrugAllergyWarningModel>>(
            $"api/v1/consultations/patients/{patientId}/drug-allergy-check",
            new DrugAllergyCheckModel(PrescriptionItems));
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            AllergyWarnings = result.Data;
            SetStatus(
                AllergyWarnings.Count > 0 ? "Allergy warning detected. Review before completing." : "No allergy conflicts found.",
                AllergyWarnings.Count > 0 ? "tone-amber" : "tone-green");
            return;
        }

        if (!isAutomatic)
        {
            SetStatus(result?.Error?.Message ?? "Allergy check failed.", "tone-amber");
        }
    }

    private async Task CompleteAsync()
    {
        if (!Guid.TryParse(Form.AppointmentIdText, out var appointmentId))
        {
            SetStatus("AppointmentId is required.", "tone-amber");
            return;
        }

        if (Guid.TryParse(Form.PatientIdText, out _))
        {
            await CheckAllergiesAsync(isAutomatic: true);
        }

        var payload = new CompleteConsultationModel(
            Form.Diagnosis,
            string.IsNullOrWhiteSpace(Form.Icd10Code) ? null : Form.Icd10Code,
            Form.ClinicalNotes,
            string.IsNullOrWhiteSpace(FollowUpDateText) ? null : DateOnly.Parse(FollowUpDateText),
            PrescriptionItems);

        IsBusy = true;
        var result = await ApiClient.PutAsync<CompleteConsultationModel, CompleteConsultationResultModel>(
            $"api/v1/consultations/appointments/{appointmentId}/complete",
            payload);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            Result = result.Data;
            Form.PatientIdText = result.Data.Prescription?.PatientId.ToString() ?? Form.PatientIdText;
            SetStatus("Consultation completed.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Consultation completion failed.", "tone-amber");
    }

    private async Task CreateLabOrderAsync()
    {
        if (!Guid.TryParse(Form.AppointmentIdText, out var appointmentId))
        {
            SetStatus("AppointmentId is required for lab order.", "tone-amber");
            return;
        }

        if (SelectedLabTests.Count == 0)
        {
            SetStatus("Select at least one lab test.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<CreateConsultationLabOrderModel, LabBookingModel>(
            $"api/v1/consultations/appointments/{appointmentId}/lab-orders",
            new CreateConsultationLabOrderModel(
                SelectedLabTests.Select(x => x.Id).ToList(),
                LabOrderCollectionType,
                null,
                string.IsNullOrWhiteSpace(LabCollectionAddress) ? null : LabCollectionAddress,
                "Ordered from consultation",
                null));
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            LabOrders = LabOrders.Concat([result.Data]).ToList();
            SelectedLabTests.Clear();
            SetStatus("Lab booking created.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Lab order failed.", "tone-amber");
    }

    private async Task DownloadPrescriptionPdfAsync()
    {
        var prescriptionId = Result?.Prescription?.Id;
        if (prescriptionId is null)
        {
            SetStatus("Prescription PDF is unavailable.", "tone-amber");
            return;
        }

        IsBusy = true;
        var download = await ApiClient.DownloadFileAsync($"api/v1/consultations/prescriptions/{prescriptionId}/pdf");
        IsBusy = false;

        if (!download.Success)
        {
            SetStatus(download.ErrorMessage ?? "Prescription PDF download failed.", "tone-amber");
            return;
        }

        await JsRuntime.InvokeVoidAsync(
            "HealthCareMSMedia.downloadFile",
            download.FileName,
            download.ContentType,
            Convert.ToBase64String(download.Content));
        SetStatus("Prescription PDF downloaded.", "tone-green");
    }

    private void OnFollowUpDateChanged(ChangeEventArgs args)
    {
        FollowUpDateText = args.Value?.ToString() ?? string.Empty;
    }

    private void ToggleLabTest(LabTestModel test)
    {
        var selected = SelectedLabTests.FirstOrDefault(x => x.Id == test.Id);
        if (selected is null)
        {
            SelectedLabTests.Add(test);
        }
        else
        {
            SelectedLabTests.Remove(selected);
        }
    }

    private string MedicineOptionClass(DrapMedicineModel medicine)
    {
        return medicine.IsBanned ? "drug-option banned" : "drug-option";
    }

    private string LabTestOptionClass(LabTestModel test)
    {
        return SelectedLabTests.Any(x => x.Id == test.Id) ? "drug-option selected" : "drug-option";
    }

    private void OpenSummary()
    {
        if (!Guid.TryParse(Form.AppointmentIdText, out var appointmentId))
        {
            SetStatus("AppointmentId is required for summary.", "tone-amber");
            return;
        }

        Navigation.NavigateTo($"/consultation/summary/{appointmentId}");
    }

    private static string ShortSignature(string? signature)
    {
        return string.IsNullOrWhiteSpace(signature) || signature.Length <= 24
            ? signature ?? string.Empty
            : $"{signature[..24]}...";
    }

    private void SetStatus(string message, string statusClass)
    {
        StatusMessage = message;
        StatusClass = statusClass;
    }

    private sealed class ConsultationForm
    {
        public string AppointmentIdText { get; set; } = string.Empty;

        public string PatientIdText { get; set; } = string.Empty;

        public string? Icd10Code { get; set; }

        public string Diagnosis { get; set; } = string.Empty;

        public string? ClinicalNotes { get; set; }
    }

    private sealed class MedicineForm
    {
        public string MedicineName { get; set; } = string.Empty;

        public string? GenericName { get; set; }

        public string? Strength { get; set; }

        public string? Route { get; set; } = "Oral";

        public string Dosage { get; set; } = string.Empty;

        public string Frequency { get; set; } = string.Empty;

        public short DurationDays { get; set; } = 5;

        public decimal Quantity { get; set; } = 10;

        public string? Instructions { get; set; }

        public bool IsSubstitutionAllowed { get; set; } = true;
    }
}
