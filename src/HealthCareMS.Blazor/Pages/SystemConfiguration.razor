    private static IEnumerable<NavigationItemModel> FlattenItems(IEnumerable<NavigationItemModel> items)
    {
        foreach (var item in items)
        {
            yield return item;
            foreach (var child in FlattenItems(item.Children))
            {
                yield return child;
            }
        }
    }

    private sealed record MenuGroupOption(string Key, string Label, IReadOnlyList<MenuItemOption> Items);

    private sealed record MenuItemOption(string Key, string Label);

    private sealed class UndoToastModel(Guid id, string message, string menuKey)
    {
        public Guid Id { get; } = id;

        public string Message { get; } = message;

        public string MenuKey { get; } = menuKey;

        public bool IsExpired { get; set; }
    }
