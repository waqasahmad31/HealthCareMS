@page "/consultation/summary/{AppointmentId:guid}"
@using HealthCareMS.Blazor.Models
@using HealthCareMS.Blazor.Services
@inject HealthCareApiClient ApiClient
@inject IJSRuntime JsRuntime

<PageTitle>Consultation Summary</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Consultation</p>
        <h1>@(Summary?.AppointmentNumber ?? "Summary")</h1>
    </div>
    <div class="header-actions">
        <button class="secondary-button" type="button" @onclick="LoadSummaryAsync" disabled="@IsBusy">Refresh</button>
        <button class="primary-button" type="button" @onclick="DownloadSummaryPdfAsync" disabled="@IsBusy">PDF</button>
    </div>
</section>

@if (Summary is null)
{
    <section class="panel">
        <div class="empty-state">Load consultation summary.</div>
    </section>
}
else
{
    <section class="stats-grid portal-stats">
        <article class="metric-card">
            <span class="metric-label">Patient</span>
            <strong>@Summary.PatientName</strong>
            <span class="tone-muted">@Summary.Status</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Doctor</span>
            <strong>@Summary.DoctorName</strong>
            <span class="tone-blue">@Summary.Icd10Code</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Medicines</span>
            <strong>@(Summary.Prescription?.Items.Count ?? 0)</strong>
            <span class="tone-green">@Summary.Prescription?.PrescriptionNumber</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Lab Orders</span>
            <strong>@Summary.LabOrders.Count</strong>
            <span class="tone-amber">bookings</span>
        </article>
    </section>

    <section class="portal-grid">
        <article class="panel">
            <div class="panel-header">
                <h2>Diagnosis</h2>
                <span class="status-pill blue">@Summary.Status</span>
            </div>
            <div class="permission-grid">
                <div class="permission-row">
                    <code>@Summary.Icd10Code</code>
                    <span>@Summary.Icd10Title</span>
                </div>
                <div class="permission-row">
                    <code>@Summary.FollowUpDate</code>
                    <span>@Summary.Diagnosis</span>
                </div>
                <div class="permission-row">
                    <code>Notes</code>
                    <span>@Summary.ClinicalNotes</span>
                </div>
            </div>
        </article>

        <article class="panel">
            <div class="panel-header">
                <h2>Prescription</h2>
                <span class="status-pill green">Rx</span>
            </div>
            <div class="table-shell">
                @foreach (var item in Summary.Prescription?.Items ?? Array.Empty<PrescriptionItemResultModel>())
                {
                    <div class="table-row prescription-row">
                        <span>@item.MedicineName</span>
                        <span>@item.Dosage / @item.Frequency</span>
                        <span>@item.Quantity</span>
                    </div>
                }
            </div>
        </article>
    </section>

    <section class="panel">
        <div class="panel-header">
            <h2>Lab Orders</h2>
            <span class="status-pill blue">@Summary.LabOrders.Count</span>
        </div>
        <div class="table-shell">
            @foreach (var order in Summary.LabOrders)
            {
                <div class="table-row summary-lab-row">
                    <span>@order.BookingNumber</span>
                    <span>@string.Join(", ", order.Items.Select(x => x.TestCode))</span>
                    <span>PKR @order.TotalAmount.ToString("0.##")</span>
                    <span class="status-pill green">@order.Status</span>
                </div>
            }
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p class="@StatusClass">@StatusMessage</p>
}

@code {
    [Parameter]
    public Guid AppointmentId { get; set; }

    private ConsultationSummaryModel? Summary { get; set; }

    private bool IsBusy { get; set; }

    private string? StatusMessage { get; set; }

    private string StatusClass { get; set; } = "tone-muted";

    protected override async Task OnInitializedAsync()
    {
        await LoadSummaryAsync();
    }

    private async Task LoadSummaryAsync()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<ConsultationSummaryModel>($"api/v1/consultations/appointments/{AppointmentId}/summary");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            Summary = result.Data;
            SetStatus("Summary loaded.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Summary unavailable.", "tone-amber");
    }

    private async Task DownloadSummaryPdfAsync()
    {
        IsBusy = true;
        var download = await ApiClient.DownloadFileAsync($"api/v1/consultations/appointments/{AppointmentId}/summary/pdf");
        IsBusy = false;

        if (!download.Success)
        {
            SetStatus(download.ErrorMessage ?? "Summary PDF download failed.", "tone-amber");
            return;
        }

        await JsRuntime.InvokeVoidAsync(
            "HealthCareMSMedia.downloadFile",
            download.FileName,
            download.ContentType,
            Convert.ToBase64String(download.Content));
        SetStatus("Summary PDF downloaded.", "tone-green");
    }

    private void SetStatus(string message, string statusClass)
    {
        StatusMessage = message;
        StatusClass = statusClass;
    }
}
