@page "/consultation/video/{SessionId:guid}"
@using System.Net.Http.Headers
@using HealthCareMS.Blazor.Models
@using HealthCareMS.Blazor.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject HealthCareApiClient ApiClient
@inject ApiEndpointOptions ApiEndpoints
@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<PageTitle>Video Consultation</PageTitle>

<section class="video-console">
    <div class="video-stage">
        <div class="remote-video">
            <span>@RemoteLabel</span>
            <strong>@(Session?.DoctorName ?? "Doctor")</strong>
        </div>
        <div class="local-video">
            <video id="consolePreview" autoplay playsinline></video>
            <span>@ParticipantType</span>
        </div>
    </div>

    <aside class="video-side-panel">
        <div class="consultation-tabs">
            <button class="@TabClass("Session")" type="button" @onclick='() => ActiveTab = "Session"'>Session</button>
            <button class="@TabClass("Chat")" type="button" @onclick='() => ActiveTab = "Chat"'>Chat</button>
            <button class="@TabClass("Vitals")" type="button" @onclick='() => ActiveTab = "Vitals"'>Vitals</button>
        </div>

        @if (ActiveTab == "Session")
        {
            <div class="panel-header">
                <h2>Session</h2>
                <span class="@ConnectionBadge">@ConnectionLabel</span>
            </div>
            @if (JoinResult is null)
            {
                <div class="empty-state">Joining session...</div>
            }
            else
            {
                <div class="session-summary compact-session-summary">
                    <div>
                        <span>Status</span>
                        <strong>@JoinResult.Session.Status</strong>
                        <span>@JoinResult.ChannelName</span>
                    </div>
                    <div>
                        <span>Patient</span>
                        <strong>@JoinResult.Session.PatientName</strong>
                        <span>@(JoinResult.PatientIsOnline ? "Online" : "Waiting")</span>
                    </div>
                    <div>
                        <span>Doctor</span>
                        <strong>@JoinResult.Session.DoctorName</strong>
                        <span>@(JoinResult.DoctorIsOnline ? "Online" : "Waiting")</span>
                    </div>
                    <div>
                        <span>Agora UID</span>
                        <strong>@JoinResult.Uid</strong>
                        <span>@JoinResult.ExpiresAt.LocalDateTime.ToString("HH:mm")</span>
                    </div>
                </div>
            }
        }
        else if (ActiveTab == "Chat")
        {
            <div class="panel-header">
                <h2>Chat</h2>
                <span class="@ChatConnectionBadge">@ChatConnectionLabel</span>
            </div>
            <div class="chat-list">
                @if (ChatMessages.Count == 0)
                {
                    <div class="empty-state">No messages yet.</div>
                }
                @foreach (var message in ChatMessages)
                {
                    <div class="@ChatMessageClass(message)">
                        <div>
                            <strong>@message.SenderDisplayName</strong>
                            <span>@message.SentAt.LocalDateTime.ToString("HH:mm")</span>
                        </div>
                        @if (message.MessageType == "File")
                        {
                            <button class="secondary-button small-button chat-file-button" type="button" @onclick="() => DownloadAttachmentAsync(message)" disabled="@IsBusy">
                                @message.AttachmentFileName
                            </button>
                        }
                        else
                        {
                            <p>@message.MessageText</p>
                        }
                        <span>@ReadReceiptLabel(message)</span>
                    </div>
                }
            </div>
            <div class="chat-compose">
                <textarea @bind="ChatText"></textarea>
                <div class="emoji-row">
                    <button type="button" class="secondary-button small-button" @onclick="() => AddEmoji(char.ConvertFromUtf32(128077))">&#128077;</button>
                    <button type="button" class="secondary-button small-button" @onclick="() => AddEmoji(char.ConvertFromUtf32(128522))">&#128522;</button>
                    <button type="button" class="secondary-button small-button" @onclick='() => AddEmoji(":)")'>:)</button>
                </div>
                <InputFile OnChange="UploadAttachmentAsync" />
                <button class="primary-button" type="button" @onclick="SendChatAsync" disabled="@IsBusy">Send</button>
            </div>
        }
        else
        {
            <div class="panel-header">
                <h2>Vitals</h2>
                <button class="secondary-button small-button" type="button" @onclick="LoadVitalsAsync" disabled="@IsBusy">Refresh</button>
            </div>
            @if (Session is null)
            {
                <div class="empty-state">Session vitals unavailable.</div>
            }
            else
            {
                <div class="vitals-compact-form">
                    <input type="datetime-local" value="@VitalsRecordedAtText" @onchange="OnVitalsRecordedAtChanged" />
                    <div class="vitals-two-column">
                        <label>Systolic<InputNumber @bind-Value="VitalsForm.SystolicBloodPressure" /></label>
                        <label>Diastolic<InputNumber @bind-Value="VitalsForm.DiastolicBloodPressure" /></label>
                        <label>Sugar<InputNumber @bind-Value="VitalsForm.BloodSugarMgDl" /></label>
                        <label>Temp C<InputNumber @bind-Value="VitalsForm.TemperatureCelsius" /></label>
                        <label>Weight<InputNumber @bind-Value="VitalsForm.WeightKg" /></label>
                        <label>Heart Rate<InputNumber @bind-Value="VitalsForm.HeartRate" /></label>
                    </div>
                    <button class="primary-button" type="button" @onclick="RecordVitalsAsync" disabled="@IsBusy">Record Vitals</button>
                </div>

                <div class="trend-grid compact-trends">
                    @foreach (var trend in VitalsTrends)
                    {
                        <div class="trend-card">
                            <span>@trend.Metric</span>
                            <strong>@TrendValue(trend)</strong>
                            <code>@TrendChange(trend)</code>
                        </div>
                    }
                </div>

                <div class="table-shell compact-vitals-history">
                    @foreach (var vital in VitalsHistory.Take(6))
                    {
                        <div class="table-row vitals-video-row">
                            <span>@vital.RecordedAt.LocalDateTime.ToString("HH:mm")</span>
                            <span>@BloodPressure(vital)</span>
                            <span>@Sugar(vital)</span>
                        </div>
                    }
                </div>
            }
        }
    </aside>
</section>

<section class="video-controls">
    <button class="secondary-button" type="button" @onclick="ToggleMute">@MuteLabel</button>
    <button class="secondary-button" type="button" @onclick="ToggleCamera">@CameraLabel</button>
    <button class="secondary-button" type="button" @onclick="ShareScreenAsync">Share Screen</button>
    <button class="primary-button" type="button" @onclick="ReloadSessionAsync" disabled="@IsBusy">Refresh</button>
</section>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p class="@StatusClass">@StatusMessage</p>
}

@code {
    [Parameter]
    public Guid SessionId { get; set; }

    private ConsultationSessionModel? Session { get; set; }

    private JoinConsultationSessionModel? JoinResult { get; set; }

    private HubConnection? HubConnection { get; set; }

    private HubConnection? ChatHubConnection { get; set; }

    private List<ChatMessageModel> ChatMessages { get; set; } = [];

    private IReadOnlyList<PatientVitalsModel> VitalsHistory { get; set; } = [];

    private IReadOnlyList<VitalTrendModel> VitalsTrends { get; set; } = [];

    private RecordVitalsModel VitalsForm { get; set; } = NewVitalsForm();

    private string VitalsRecordedAtText { get; set; } = ToDateTimeLocal(DateTimeOffset.UtcNow);

    private string ParticipantType { get; set; } = "Patient";

    private string ActiveTab { get; set; } = "Session";

    private string ChatText { get; set; } = string.Empty;

    private bool IsBusy { get; set; }

    private bool IsMuted { get; set; }

    private bool IsCameraOff { get; set; }

    private bool PreviewStarted { get; set; }

    private string? StatusMessage { get; set; }

    private string StatusClass { get; set; } = "tone-muted";

    private string ConnectionLabel => HubConnection?.State == HubConnectionState.Connected ? "Live" : "Offline";

    private string ConnectionBadge => HubConnection?.State == HubConnectionState.Connected ? "status-pill green" : "status-pill amber";

    private string ChatConnectionLabel => ChatHubConnection?.State == HubConnectionState.Connected ? "Live" : "Offline";

    private string ChatConnectionBadge => ChatHubConnection?.State == HubConnectionState.Connected ? "status-pill green" : "status-pill amber";

    private string RemoteLabel => ParticipantType == "Doctor" ? "Patient Feed" : "Doctor Feed";

    private string MuteLabel => IsMuted ? "Unmute" : "Mute";

    private string CameraLabel => IsCameraOff ? "Camera On" : "Camera Off";

    protected override async Task OnInitializedAsync()
    {
        ParticipantType = GetRoleFromQuery();
        await EnsureHubAsync();
        await EnsureChatHubAsync();
        await ReloadSessionAsync();
        await JoinAsync();
        await LoadChatAsync();
        await LoadVitalsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!PreviewStarted)
        {
            PreviewStarted = true;
            var result = await JsRuntime.InvokeAsync<MediaPreviewResult>("HealthCareMSMedia.startPreview", "consolePreview");
            SetStatus(result.Message, result.Success ? "tone-green" : "tone-amber");
            StateHasChanged();
        }
    }

    private async Task ReloadSessionAsync()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<ConsultationSessionModel>($"api/v1/consultations/sessions/{SessionId}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            Session = result.Data;
            if (HubConnection?.State == HubConnectionState.Connected)
            {
                await HubConnection.InvokeAsync("JoinSession", Session.Id);
            }
            if (ChatHubConnection?.State == HubConnectionState.Connected)
            {
                await ChatHubConnection.InvokeAsync("JoinSession", Session.Id);
            }

            SetStatus("Session loaded.", "tone-green");
            await LoadVitalsAsync();
            return;
        }

        SetStatus(result?.Error?.Message ?? "Session unavailable.", "tone-amber");
    }

    private async Task JoinAsync()
    {
        IsBusy = true;
        var result = await ApiClient.PostAsync<JoinConsultationSessionRequestModel, JoinConsultationSessionModel>(
            $"api/v1/consultations/sessions/{SessionId}/join",
            new JoinConsultationSessionRequestModel { ParticipantType = ParticipantType });
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            JoinResult = result.Data;
            Session = result.Data.Session;
            await MarkChatReadAsync();
            await LoadVitalsAsync();
            SetStatus($"{ParticipantType} joined video session.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Join failed.", "tone-amber");
    }

    private async Task EnsureHubAsync()
    {
        HubConnection = new HubConnectionBuilder()
            .WithUrl(ApiEndpoints.ConsultationHubUrl)
            .WithAutomaticReconnect()
            .Build();

        HubConnection.On<object>("SessionChanged", _ =>
        {
            SetStatus("Session activity updated.", "tone-blue");
            _ = InvokeAsync(ReloadSessionAsync);
        });

        await HubConnection.StartAsync();
    }

    private async Task EnsureChatHubAsync()
    {
        ChatHubConnection = new HubConnectionBuilder()
            .WithUrl(ApiEndpoints.ConsultationChatHubUrl)
            .WithAutomaticReconnect()
            .Build();

        ChatHubConnection.On<ChatMessageModel>("MessageReceived", message =>
        {
            UpsertChatMessage(message);
            _ = InvokeAsync(async () =>
            {
                await MarkChatReadAsync();
                StateHasChanged();
            });
        });

        ChatHubConnection.On<IReadOnlyList<ChatMessageModel>>("ReadReceiptsUpdated", messages =>
        {
            foreach (var message in messages)
            {
                UpsertChatMessage(message);
            }

            _ = InvokeAsync(StateHasChanged);
        });

        await ChatHubConnection.StartAsync();
        await ChatHubConnection.InvokeAsync("JoinSession", SessionId);
    }

    private async Task LoadChatAsync()
    {
        var result = await ApiClient.GetAsync<IReadOnlyList<ChatMessageModel>>($"api/v1/consultations/sessions/{SessionId}/chat/messages");
        if (result?.Success == true && result.Data is not null)
        {
            ChatMessages = result.Data.OrderBy(x => x.SentAt).ToList();
            await MarkChatReadAsync();
        }
    }

    private async Task LoadVitalsAsync()
    {
        if (Session is null)
        {
            return;
        }

        var history = await ApiClient.GetAsync<IReadOnlyList<PatientVitalsModel>>($"api/v1/patients/{Session.PatientId}/vitals");
        var trends = await ApiClient.GetAsync<IReadOnlyList<VitalTrendModel>>($"api/v1/patients/{Session.PatientId}/vitals/trends");

        if (history?.Success == true && history.Data is not null)
        {
            VitalsHistory = history.Data;
        }

        if (trends?.Success == true && trends.Data is not null)
        {
            VitalsTrends = trends.Data;
        }
    }

    private async Task RecordVitalsAsync()
    {
        if (Session is null)
        {
            SetStatus("Session patient is unavailable.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<RecordVitalsModel, PatientVitalsModel>(
            $"api/v1/patients/{Session.PatientId}/vitals",
            VitalsForm);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            VitalsForm = NewVitalsForm();
            VitalsRecordedAtText = ToDateTimeLocal(VitalsForm.RecordedAt ?? DateTimeOffset.UtcNow);
            await LoadVitalsAsync();
            SetStatus("Vitals recorded.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Vitals recording failed.", "tone-amber");
    }

    private void OnVitalsRecordedAtChanged(ChangeEventArgs args)
    {
        VitalsRecordedAtText = args.Value?.ToString() ?? string.Empty;
        VitalsForm.RecordedAt = DateTimeOffset.TryParse(VitalsRecordedAtText, out var parsed)
            ? parsed
            : DateTimeOffset.UtcNow;
    }

    private async Task SendChatAsync()
    {
        if (string.IsNullOrWhiteSpace(ChatText))
        {
            SetStatus("Message is required.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<SendChatMessageModel, ChatMessageModel>(
            $"api/v1/consultations/sessions/{SessionId}/chat/messages",
            new SendChatMessageModel
            {
                ParticipantType = ParticipantType,
                SenderDisplayName = SenderDisplayName,
                MessageText = ChatText
            });
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            UpsertChatMessage(result.Data);
            ChatText = string.Empty;
            SetStatus("Message sent.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Message failed.", "tone-amber");
    }

    private async Task UploadAttachmentAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var content = new MultipartFormDataContent();
        using var streamContent = new StreamContent(stream);
        streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
        content.Add(new StringContent(ParticipantType), "participantType");
        content.Add(new StringContent(SenderDisplayName), "senderDisplayName");
        content.Add(streamContent, "file", file.Name);

        IsBusy = true;
        var result = await ApiClient.PostMultipartAsync<ChatMessageModel>(
            $"api/v1/consultations/sessions/{SessionId}/chat/attachments",
            content);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            UpsertChatMessage(result.Data);
            SetStatus("Attachment uploaded.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Attachment upload failed.", "tone-amber");
    }

    private async Task MarkChatReadAsync()
    {
        var result = await ApiClient.PutAsync<MarkChatMessagesReadModel, IReadOnlyList<ChatMessageModel>>(
            $"api/v1/consultations/sessions/{SessionId}/chat/read",
            new MarkChatMessagesReadModel { ParticipantType = ParticipantType });

        if (result?.Success == true && result.Data is not null)
        {
            ChatMessages = result.Data.OrderBy(x => x.SentAt).ToList();
        }
    }

    private async Task DownloadAttachmentAsync(ChatMessageModel message)
    {
        if (string.IsNullOrWhiteSpace(message.DownloadUrl))
        {
            SetStatus("Attachment is unavailable.", "tone-amber");
            return;
        }

        var download = await ApiClient.DownloadFileAsync(message.DownloadUrl.TrimStart('/'));
        if (!download.Success)
        {
            SetStatus(download.ErrorMessage ?? "Download failed.", "tone-amber");
            return;
        }

        await JsRuntime.InvokeVoidAsync(
            "HealthCareMSMedia.downloadFile",
            download.FileName,
            download.ContentType,
            Convert.ToBase64String(download.Content));
        SetStatus("Attachment downloaded.", "tone-green");
    }

    private void ToggleMute()
    {
        IsMuted = !IsMuted;
        SetStatus(IsMuted ? "Microphone muted." : "Microphone unmuted.", "tone-muted");
    }

    private void ToggleCamera()
    {
        IsCameraOff = !IsCameraOff;
        SetStatus(IsCameraOff ? "Camera paused." : "Camera resumed.", "tone-muted");
    }

    private Task ShareScreenAsync()
    {
        SetStatus("Screen share requested.", "tone-blue");
        return Task.CompletedTask;
    }

    private void AddEmoji(string value)
    {
        ChatText = $"{ChatText}{value}";
    }

    private void UpsertChatMessage(ChatMessageModel message)
    {
        var index = ChatMessages.FindIndex(x => x.Id == message.Id);
        if (index >= 0)
        {
            ChatMessages[index] = message;
        }
        else
        {
            ChatMessages.Add(message);
        }

        ChatMessages = ChatMessages.OrderBy(x => x.SentAt).ToList();
    }

    private string SenderDisplayName => ParticipantType == "Doctor"
        ? Session?.DoctorName ?? "Doctor"
        : Session?.PatientName ?? "Patient";

    private string ChatMessageClass(ChatMessageModel message)
    {
        return message.SenderType == ParticipantType ? "chat-message mine" : "chat-message theirs";
    }

    private string ReadReceiptLabel(ChatMessageModel message)
    {
        return ParticipantType == "Patient"
            ? message.DoctorReadAt.HasValue ? "Read by doctor" : "Sent"
            : message.PatientReadAt.HasValue ? "Read by patient" : "Sent";
    }

    private static RecordVitalsModel NewVitalsForm()
    {
        return new RecordVitalsModel
        {
            RecordedAt = DateTimeOffset.UtcNow,
            BloodSugarContext = "Random"
        };
    }

    private static string ToDateTimeLocal(DateTimeOffset value)
    {
        return value.LocalDateTime.ToString("yyyy-MM-ddTHH:mm");
    }

    private static string TrendValue(VitalTrendModel trend)
    {
        return trend.LatestValue.HasValue ? $"{trend.LatestValue:0.##} {trend.Unit}" : "-";
    }

    private static string TrendChange(VitalTrendModel trend)
    {
        return trend.Change.HasValue ? $"{trend.Direction} {trend.Change:+0.##;-0.##;0}" : trend.Direction;
    }

    private static string BloodPressure(PatientVitalsModel vital)
    {
        return vital.SystolicBloodPressure.HasValue && vital.DiastolicBloodPressure.HasValue
            ? $"{vital.SystolicBloodPressure}/{vital.DiastolicBloodPressure}"
            : "-";
    }

    private static string Sugar(PatientVitalsModel vital)
    {
        return vital.BloodSugarMgDl.HasValue
            ? $"{vital.BloodSugarMgDl:0.##}"
            : "-";
    }

    private string TabClass(string tab)
    {
        return ActiveTab == tab ? "tab-button active" : "tab-button";
    }

    private string GetRoleFromQuery()
    {
        var query = new Uri(NavigationManagerUri()).Query.TrimStart('?');
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2
                && string.Equals(Uri.UnescapeDataString(parts[0]), "role", StringComparison.OrdinalIgnoreCase)
                && string.Equals(Uri.UnescapeDataString(parts[1]), "Doctor", StringComparison.OrdinalIgnoreCase))
            {
                return "Doctor";
            }
        }

        return "Patient";
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = null!;

    private string NavigationManagerUri()
    {
        return Navigation.Uri;
    }

    private void SetStatus(string message, string statusClass)
    {
        StatusMessage = message;
        StatusClass = statusClass;
    }

    public async ValueTask DisposeAsync()
    {
        await JsRuntime.InvokeVoidAsync("HealthCareMSMedia.stopPreview", "consolePreview");
        if (HubConnection is not null)
        {
            await HubConnection.DisposeAsync();
        }
        if (ChatHubConnection is not null)
        {
            await ChatHubConnection.DisposeAsync();
        }
    }

    private sealed record MediaPreviewResult(bool Success, string Message, int VideoTracks, int AudioTracks);
}
