@page "/patients"
@page "/doctors"
@page "/appointments"
@page "/payments"
@inject NavigationManager Navigation

<PageTitle>HealthCareMS Module</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Module Workspace</p>
        <h1>@Title</h1>
    </div>
    <span class="status-pill amber">Planned</span>
</section>

<section class="panel">
    <div class="module-grid">
        <div class="module-tile">
            <strong>Domain</strong>
            <span>@DomainState</span>
        </div>
        <div class="module-tile">
            <strong>API</strong>
            <span>@ApiState</span>
        </div>
        <div class="module-tile">
            <strong>UI</strong>
            <span>@UiState</span>
        </div>
    </div>
</section>

@code {
    private string Path => Navigation.ToBaseRelativePath(Navigation.Uri);

    private string Title => Path switch
    {
        "patients" => "Patients",
        "doctors" => "Doctors",
        "appointments" => "Appointments",
        "pharmacy" => "Pharmacy",
        "laboratory" => "Laboratory",
        "payments" => "Payments",
        _ => "Module"
    };

    private string DomainState => Path is "patients" or "doctors" ? "Foundation added" : "Scheduled";

    private string ApiState => Path is "patients" or "doctors" ? "Next endpoints" : "Scheduled";

    private string UiState => "Workspace shell";
}
