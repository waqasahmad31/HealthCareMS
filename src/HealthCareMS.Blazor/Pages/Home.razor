@page "/"

<PageTitle>HealthCareMS Dashboard</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Enterprise Healthcare Management</p>
        <h1>Operations Dashboard</h1>
    </div>
    <div class="header-actions action-cluster">
        <a class="secondary-button" href="/analytics">Open Analytics</a>
        <a class="primary-button" href="/tenants">Manage Tenants</a>
    </div>
</section>

<section class="stats-grid">
    @foreach (var stat in Stats)
    {
        <article class="metric-card">
            <span class="metric-label">@stat.Label</span>
            <strong>@stat.Value</strong>
            <span class="@stat.Tone">@stat.Change</span>
        </article>
    }
</section>

<section class="work-grid">
    <article class="panel queue-panel">
        <div class="panel-header">
            <h2>Today</h2>
            <span class="status-pill blue">Live</span>
        </div>
        <div class="queue-list">
            @foreach (var item in Queue)
            {
                <div class="queue-row">
                    <div>
                        <strong>@item.Title</strong>
                        <span>@item.Detail</span>
                    </div>
                    <span class="@item.BadgeClass">@item.Status</span>
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>Modules</h2>
            <span class="status-pill green">Enabled</span>
        </div>
        <div class="module-grid">
            @foreach (var module in Modules)
            {
                <div class="module-tile">
                    <strong>@module.Name</strong>
                    <span>@module.Status</span>
                </div>
            }
        </div>
    </article>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Care Journeys</h2>
        <span class="status-pill amber">Guided flow</span>
    </div>
    <div class="module-grid">
        @foreach (var item in Journeys)
        {
            <a class="module-tile" href="@item.Route">
                <strong>@item.Name</strong>
                <span>@item.Caption</span>
            </a>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Permission Baseline</h2>
        <span class="status-pill amber">Super Admin</span>
    </div>
    <div class="permission-grid">
        @foreach (var permission in Permissions)
        {
            <div class="permission-row">
                <code>@permission.Key</code>
                <span>@permission.Scope</span>
            </div>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Enterprise Launchpad</h2>
        <span class="status-pill green">S23-S36</span>
    </div>
    <div class="module-grid">
        @foreach (var item in Launchpad)
        {
            <a class="module-tile" href="@item.Route">
                <strong>@item.Name</strong>
                <span>@item.Caption</span>
            </a>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Core Workspaces</h2>
        <span class="status-pill blue">Operational</span>
    </div>
    <div class="module-grid">
        @foreach (var item in CoreWorkspaces)
        {
            <a class="module-tile" href="@item.Route">
                <strong>@item.Name</strong>
                <span>@item.Caption</span>
            </a>
        }
    </div>
</section>

@code {
    private readonly DashboardStat[] Stats =
    [
        new("Active Tenants", "Live", "Ready for onboarding", "tone-blue"),
        new("Patients", "Timeline", "Unified patient health view", "tone-muted"),
        new("Doctors", "Best Match", "Recommendation engine enabled", "tone-amber"),
        new("Revenue", "Payments", "Checkout + refunds + analytics", "tone-green")
    ];

    private readonly QueueItem[] Queue =
    [
        new("Payments center", "JazzCash, EasyPaisa, Stripe checkout with invoice/refund simulation", "Ready", "status-pill green"),
        new("Lab workflow", "Home collection, result entry, validation, release, QR reports", "Live", "status-pill blue"),
        new("Analytics center", "Cross-module revenue, utilization, TAT, fulfillment", "Ready", "status-pill amber"),
        new("Security center", "Sessions, login history, 2FA controls", "Ready", "status-pill amber")
    ];

    private readonly ModuleTile[] Modules =
    [
        new("Identity", "Users, roles, permissions"),
        new("Patient", "Timeline + emergency QR"),
        new("Doctor", "Discovery + recommendations"),
        new("Appointment", "Consultation lifecycle"),
        new("Pharmacy", "Payments + reconciliation"),
        new("Laboratory", "Home collection + released reports"),
        new("Security", "Sessions + 2FA")
    ];

    private readonly PermissionPreview[] Permissions =
    [
        new("system.superadmin.*", "Platform"),
        new("system.tenants.create", "Tenant Management"),
        new("tenant.users.create", "Tenant Admin"),
        new("pharmacy.orders.process", "Pharmacy"),
        new("lab.results.release", "Laboratory"),
        new("doctor.verify", "Doctor Admin")
    ];

    private readonly LaunchpadItem[] Journeys =
    [
        new("Patient Intake To Booking", "/patients", "Register or search a patient, then carry context into appointment booking"),
        new("Doctor Readiness", "/doctors", "Credential, verify, and prepare weekly schedule coverage"),
        new("Operational Scheduling", "/appointments", "Guide patient + doctor context into lifecycle-controlled appointments"),
        new("Go-Live Support", "/help", "Training assets, rollout guidance, and support handover")
    ];

    private readonly LaunchpadItem[] Launchpad =
    [
        new("Payments Center", "/payments", "Gateway sessions, invoices, refunds"),
        new("Pharmacy Reports", "/pharmacy/reports", "Sales, valuation, reconciliation"),
        new("Lab Workflow", "/lab-workflow", "Collection to report release"),
        new("Health Timeline", "/timeline", "Patient summary and emergency QR"),
        new("Analytics Center", "/analytics", "Cross-module KPIs"),
        new("Security Center", "/security", "2FA, sessions, login history"),
        new("Doctor Discovery", "/doctor-discovery", "Best-match recommendation engine"),
        new("Help Center", "/help", "Guides and rollout handover")
    ];

    private readonly LaunchpadItem[] CoreWorkspaces =
    [
        new("Patients Workspace", "/patients", "Registry, medical history, vitals"),
        new("Doctors Workspace", "/doctors", "Discovery, verification, schedules"),
        new("Appointments Workspace", "/appointments", "Booking, reschedule, completion")
    ];

    private sealed record DashboardStat(string Label, string Value, string Change, string Tone);

    private sealed record QueueItem(string Title, string Detail, string Status, string BadgeClass);

    private sealed record ModuleTile(string Name, string Status);

    private sealed record PermissionPreview(string Key, string Scope);

    private sealed record LaunchpadItem(string Name, string Route, string Caption);
}
