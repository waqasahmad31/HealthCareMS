@page "/pharmacy"
@using System.Net.Http.Headers
@using HealthCareMS.Blazor.Models
@using HealthCareMS.Blazor.Services
@inject HealthCareApiClient ApiClient

<PageTitle>Pharmacy Catalogue</PageTitle>

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Pharmacy Admin</p>
        <h1>Medicine Catalogue</h1>
    </div>
    <div class="header-actions">
        <button class="secondary-button" type="button" @onclick="LoadMedicinesAsync" disabled="@IsBusy">Refresh</button>
        <button class="secondary-button" type="button" @onclick="RunAlertScanAsync" disabled="@IsBusy">Scan Alerts</button>
        <button class="primary-button" type="button" @onclick="CreateMedicineAsync" disabled="@IsBusy">Add Medicine</button>
    </div>
</section>

@if (StockDashboard is not null)
{
    <section class="stats-grid portal-stats">
        <article class="metric-card">
            <span class="metric-label">Medicines</span>
            <strong>@StockDashboard.TotalMedicines</strong>
            <span class="tone-muted">catalogue</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Low Stock</span>
            <strong>@StockDashboard.LowStockCount</strong>
            <span class="tone-amber">reorder alerts</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Expiry Alerts</span>
            <strong>@StockDashboard.ExpiryAlertCount</strong>
            <span class="tone-blue">30/60/90 days</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Open Alerts</span>
            <strong>@StockDashboard.OpenAlerts.Count</strong>
            <span class="tone-green">active</span>
        </article>
    </section>
}

<section class="portal-grid">
    <article class="panel">
        <div class="panel-header">
            <h2>Catalogue</h2>
            <span class="status-pill blue">@Medicines.Count</span>
        </div>
        <div class="entity-form pharmacy-filter">
            <label>
                Search
                <InputText @bind-Value="Search" />
            </label>
            <button class="secondary-button" type="button" @onclick="LoadMedicinesAsync" disabled="@IsBusy">Search</button>
        </div>
        <div class="table-shell">
            <div class="table-row table-head pharmacy-row">
                <span>Medicine</span>
                <span>DRAP</span>
                <span>Stock</span>
                <span></span>
            </div>
            @foreach (var medicine in Medicines)
            {
                <div class="table-row pharmacy-row">
                    <span>@medicine.BrandName (@medicine.GenericName)</span>
                    <span>@medicine.DrapRegistrationNumber</span>
                    <span>@medicine.StockOnHand / reorder @medicine.ReorderLevel</span>
                    <button class="secondary-button small-button" type="button" @onclick="() => SelectMedicineAsync(medicine)">Select</button>
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>Add Medicine</h2>
            <span class="status-pill green">CRUD</span>
        </div>
        <EditForm Model="MedicineForm" class="entity-form">
            <label>BrandName<InputText @bind-Value="MedicineForm.BrandName" /></label>
            <label>GenericName<InputText @bind-Value="MedicineForm.GenericName" /></label>
            <label>DosageForm<InputText @bind-Value="MedicineForm.DosageForm" /></label>
            <label>Strength<InputText @bind-Value="MedicineForm.Strength" /></label>
            <label>DRAP Registration<InputText @bind-Value="MedicineForm.DrapRegistrationNumber" /></label>
            <label>Manufacturer<InputText @bind-Value="MedicineForm.Manufacturer" /></label>
            <label>UnitPrice<InputNumber @bind-Value="MedicineForm.UnitPrice" /></label>
            <label>UnitCostPrice<InputNumber @bind-Value="MedicineForm.UnitCostPrice" /></label>
            <label>ReorderLevel<InputNumber @bind-Value="MedicineForm.ReorderLevel" /></label>
            <label>Barcode<InputText @bind-Value="MedicineForm.Barcode" /></label>
            <label class="checkbox-label">
                <InputCheckbox @bind-Value="MedicineForm.IsControlled" />
                Controlled
            </label>
        </EditForm>
    </article>
</section>

<section class="portal-grid">
    <article class="panel">
        <div class="panel-header">
            <h2>Stock Batch</h2>
            <span class="status-pill amber">@SelectedMedicine?.BrandName</span>
        </div>
        <EditForm Model="BatchForm" class="entity-form">
            <label>BatchNumber<InputText @bind-Value="BatchForm.BatchNumber" /></label>
            <label>ManufacturedDate<input type="date" value="@ManufacturedDateText" @onchange="OnManufacturedDateChanged" /></label>
            <label>ExpiryDate<input type="date" value="@ExpiryDateText" @onchange="OnExpiryDateChanged" /></label>
            <label>QuantityOnHand<InputNumber @bind-Value="BatchForm.QuantityOnHand" /></label>
            <label>UnitCostPrice<InputNumber @bind-Value="BatchForm.UnitCostPrice" /></label>
            <button class="primary-button" type="button" @onclick="AddBatchAsync" disabled="@IsBusy">Add Batch</button>
        </EditForm>
        <div class="table-shell stock-batch-list">
            @foreach (var batch in SelectedBatches)
            {
                <div class="@BatchRowClass(batch)">
                    <span>@batch.BatchNumber</span>
                    <span>@batch.QuantityOnHand units</span>
                    <span>@batch.ExpiryDate</span>
                    <button class="secondary-button small-button" type="button" @onclick="() => SelectBatch(batch)">Adjust</button>
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>Bulk CSV Import</h2>
            <span class="status-pill blue">CSV</span>
        </div>
        <div class="entity-form">
            <InputFile OnChange="ImportCsvAsync" />
            <p class="tone-muted">Columns: GenericName, BrandName, DosageForm, Strength, DrapRegistrationNumber, Manufacturer, UnitPrice, UnitCostPrice, IsControlled, ReorderLevel, Barcode</p>
        </div>
    </article>
</section>

<section class="portal-grid">
    <article class="panel">
        <div class="panel-header">
            <h2>Stock Adjustment</h2>
            <span class="status-pill amber">@SelectedBatch?.BatchNumber</span>
        </div>
        <EditForm Model="AdjustmentForm" class="entity-form">
            <label>
                AdjustmentType
                <InputSelect @bind-Value="AdjustmentForm.AdjustmentType">
                    <option>Increase</option>
                    <option>Decrease</option>
                    <option>Correction</option>
                    <option>Damaged</option>
                    <option>Expired</option>
                </InputSelect>
            </label>
            <label>QuantityDelta<InputNumber @bind-Value="AdjustmentForm.QuantityDelta" /></label>
            <label>Reason<InputTextArea @bind-Value="AdjustmentForm.Reason" /></label>
            <button class="primary-button" type="button" @onclick="AdjustBatchAsync" disabled="@IsBusy">Apply Adjustment</button>
        </EditForm>
    </article>

    <article class="panel">
        <div class="panel-header">
            <h2>FIFO Dispense</h2>
            <span class="status-pill green">@SelectedMedicine?.BrandName</span>
        </div>
        <EditForm Model="FifoForm" class="entity-form">
            <label>QuantityRequired<InputNumber @bind-Value="FifoForm.QuantityRequired" /></label>
            <label>Reason<InputText @bind-Value="FifoForm.Reason" /></label>
            <div class="header-actions">
                <button class="secondary-button" type="button" @onclick="PreviewFifoAsync" disabled="@IsBusy">Preview FIFO</button>
                <button class="primary-button" type="button" @onclick="DispenseFifoAsync" disabled="@IsBusy">Dispense FIFO</button>
            </div>
        </EditForm>
        @if (FifoSelection is not null)
        {
            <div class="table-shell">
                @foreach (var item in FifoSelection.Batches)
                {
                    <div class="table-row fifo-row">
                        <span>@item.BatchNumber</span>
                        <span>@item.QuantitySelected / @item.QuantityAvailable</span>
                        <span>@item.ReceivedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                }
            </div>
        }
    </article>
</section>

@if (StockDashboard?.OpenAlerts.Count > 0)
{
    <section class="panel">
        <div class="panel-header">
            <h2>Stock Alerts</h2>
            <span class="status-pill amber">@StockDashboard.OpenAlerts.Count</span>
        </div>
        <div class="table-shell">
            @foreach (var alert in StockDashboard.OpenAlerts.Take(12))
            {
                <div class="table-row stock-alert-row">
                    <span>@alert.MedicineName</span>
                    <span>@alert.AlertType / @alert.Severity</span>
                    <span>@alert.Message</span>
                </div>
            }
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p class="@StatusClass">@StatusMessage</p>
}

@code {
    private IReadOnlyList<MedicineModel> Medicines { get; set; } = [];

    private PharmacyStockDashboardModel? StockDashboard { get; set; }

    private MedicineModel? SelectedMedicine { get; set; }

    private IReadOnlyList<StockBatchModel> SelectedBatches { get; set; } = [];

    private StockBatchModel? SelectedBatch { get; set; }

    private MedicineFormModel MedicineForm { get; set; } = new();

    private StockBatchFormModel BatchForm { get; set; } = new();

    private StockAdjustmentFormModel AdjustmentForm { get; set; } = new();

    private FifoDispenseFormModel FifoForm { get; set; } = new();

    private FifoBatchSelectionModel? FifoSelection { get; set; }

    private string Search { get; set; } = string.Empty;

    private string ManufacturedDateText { get; set; } = string.Empty;

    private string ExpiryDateText { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow.Date.AddMonths(12)).ToString("yyyy-MM-dd");

    private bool IsBusy { get; set; }

    private string? StatusMessage { get; set; }

    private string StatusClass { get; set; } = "tone-muted";

    protected override async Task OnInitializedAsync()
    {
        await LoadStockDashboardAsync();
        await LoadMedicinesAsync();
    }

    private async Task LoadStockDashboardAsync()
    {
        var result = await ApiClient.GetAsync<PharmacyStockDashboardModel>("api/v1/pharmacy/stock/dashboard");
        if (result?.Success == true && result.Data is not null)
        {
            StockDashboard = result.Data;
        }
    }

    private async Task LoadMedicinesAsync()
    {
        IsBusy = true;
        var result = await ApiClient.GetAsync<IReadOnlyList<MedicineModel>>($"api/v1/pharmacy/medicines?search={Uri.EscapeDataString(Search)}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            Medicines = result.Data;
            await LoadStockDashboardAsync();
            SetStatus("Medicines loaded.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Medicine catalogue unavailable.", "tone-amber");
    }

    private async Task CreateMedicineAsync()
    {
        IsBusy = true;
        var result = await ApiClient.PostAsync<MedicineFormModel, MedicineModel>("api/v1/pharmacy/medicines", MedicineForm);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            MedicineForm = new MedicineFormModel();
            await LoadMedicinesAsync();
            SetStatus("Medicine added.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Medicine add failed.", "tone-amber");
    }

    private async Task AddBatchAsync()
    {
        if (SelectedMedicine is null)
        {
            SetStatus("Select a medicine first.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<StockBatchFormModel, StockBatchModel>(
            $"api/v1/pharmacy/medicines/{SelectedMedicine.Id}/stock-batches",
            BatchForm);
        IsBusy = false;

        if (result?.Success == true)
        {
            BatchForm = new StockBatchFormModel();
            ExpiryDateText = BatchForm.ExpiryDate.ToString("yyyy-MM-dd");
            await LoadMedicinesAsync();
            await LoadSelectedBatchesAsync();
            SetStatus("Stock batch added.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Stock batch add failed.", "tone-amber");
    }

    private async Task ImportCsvAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
        using var content = new MultipartFormDataContent();
        using var streamContent = new StreamContent(stream);
        streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
        content.Add(streamContent, "file", file.Name);

        IsBusy = true;
        var result = await ApiClient.PostMultipartAsync<MedicineImportModel>("api/v1/pharmacy/medicines/import", content);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            await LoadMedicinesAsync();
            SetStatus($"{result.Data.ImportedCount} medicines imported.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "CSV import failed.", "tone-amber");
    }

    private async Task SelectMedicineAsync(MedicineModel medicine)
    {
        SelectedMedicine = medicine;
        BatchForm.UnitCostPrice = medicine.UnitCostPrice;
        FifoSelection = null;
        SelectedBatch = null;
        await LoadSelectedBatchesAsync();
        SetStatus($"{medicine.BrandName} selected.", "tone-blue");
    }

    private async Task LoadSelectedBatchesAsync()
    {
        if (SelectedMedicine is null)
        {
            SelectedBatches = [];
            return;
        }

        var result = await ApiClient.GetAsync<IReadOnlyList<StockBatchModel>>($"api/v1/pharmacy/medicines/{SelectedMedicine.Id}/stock-batches");
        if (result?.Success == true && result.Data is not null)
        {
            SelectedBatches = result.Data;
        }
    }

    private void SelectBatch(StockBatchModel batch)
    {
        SelectedBatch = batch;
        AdjustmentForm = new StockAdjustmentFormModel();
        SetStatus($"{batch.BatchNumber} selected for adjustment.", "tone-blue");
    }

    private async Task AdjustBatchAsync()
    {
        if (SelectedBatch is null)
        {
            SetStatus("Select a stock batch first.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<StockAdjustmentFormModel, StockAdjustmentModel>(
            $"api/v1/pharmacy/stock-batches/{SelectedBatch.Id}/adjustments",
            AdjustmentForm);
        IsBusy = false;

        if (result?.Success == true)
        {
            AdjustmentForm = new StockAdjustmentFormModel();
            await LoadMedicinesAsync();
            await LoadSelectedBatchesAsync();
            SetStatus("Stock adjustment applied.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Stock adjustment failed.", "tone-amber");
    }

    private async Task PreviewFifoAsync()
    {
        if (SelectedMedicine is null)
        {
            SetStatus("Select a medicine first.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.GetAsync<FifoBatchSelectionModel>(
            $"api/v1/pharmacy/medicines/{SelectedMedicine.Id}/fifo-selection?quantityRequired={FifoForm.QuantityRequired}");
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            FifoSelection = result.Data;
            SetStatus(result.Data.IsFulfillable ? "FIFO selection ready." : "FIFO selection has insufficient stock.", result.Data.IsFulfillable ? "tone-green" : "tone-amber");
            return;
        }

        SetStatus(result?.Error?.Message ?? "FIFO preview failed.", "tone-amber");
    }

    private async Task DispenseFifoAsync()
    {
        if (SelectedMedicine is null)
        {
            SetStatus("Select a medicine first.", "tone-amber");
            return;
        }

        IsBusy = true;
        var result = await ApiClient.PostAsync<FifoDispenseFormModel, FifoDispenseModel>(
            $"api/v1/pharmacy/medicines/{SelectedMedicine.Id}/fifo-dispense",
            FifoForm);
        IsBusy = false;

        if (result?.Success == true && result.Data is not null)
        {
            await LoadMedicinesAsync();
            await LoadSelectedBatchesAsync();
            FifoSelection = new FifoBatchSelectionModel(
                result.Data.MedicineId,
                result.Data.MedicineName,
                result.Data.QuantityRequired,
                result.Data.QuantityDispensed,
                result.Data.QuantityDispensed == result.Data.QuantityRequired,
                result.Data.Batches);
            SetStatus("FIFO stock dispensed.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "FIFO dispense failed.", "tone-amber");
    }

    private async Task RunAlertScanAsync()
    {
        IsBusy = true;
        var result = await ApiClient.PostAsync<IReadOnlyList<StockAlertModel>>("api/v1/pharmacy/stock/alerts/scan");
        IsBusy = false;

        if (result?.Success == true)
        {
            await LoadStockDashboardAsync();
            SetStatus($"{result.Data?.Count ?? 0} stock alerts created.", "tone-green");
            return;
        }

        SetStatus(result?.Error?.Message ?? "Stock alert scan failed.", "tone-amber");
    }

    private string BatchRowClass(StockBatchModel batch)
    {
        return SelectedBatch?.Id == batch.Id ? "table-row stock-batch-row selected" : "table-row stock-batch-row";
    }

    private void OnManufacturedDateChanged(ChangeEventArgs args)
    {
        ManufacturedDateText = args.Value?.ToString() ?? string.Empty;
        BatchForm.ManufacturedDate = DateOnly.TryParse(ManufacturedDateText, out var parsed) ? parsed : null;
    }

    private void OnExpiryDateChanged(ChangeEventArgs args)
    {
        ExpiryDateText = args.Value?.ToString() ?? string.Empty;
        if (DateOnly.TryParse(ExpiryDateText, out var parsed))
        {
            BatchForm.ExpiryDate = parsed;
        }
    }

    private void SetStatus(string message, string statusClass)
    {
        StatusMessage = message;
        StatusClass = statusClass;
    }
}
